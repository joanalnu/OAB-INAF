    "popt, pcov = curve_fit(model, z, dl, p0=[1.0, 1.0, 70.0], bounds=([0.0, 0.0, 60.0], [2.0, 2.0, 80.0]), sigma=total_err)\n",
    "Om_fit, Ode_fit, H0_fit = popt\n",
    "\n",
    "for i in range(len(Om)):\n",
    "    for j in range(len(Ode)):\n",
