    "                mask[i,j,k] = True\n",
    "                chi_surface[i,j,k] = 1e4\n",
    "                continue\n",
    "\n",
    "            residuals = dl - cosmo.luminosity_distance(z).value\n",
    "            dof = len(z)-2\n",
    "            chi_surface[i,j,k] = np.sum((residuals/total_err)**2)/dof\n",
    "\n",
    "\n",
    "masked_chi_surface = np.ma.array(chi_surface, mask=mask)\n",
    "\n",
    "# Find best fit parameters\n",
    "print(f\"Best fit parameters: Om = {Om_fit:.2f}, Ode = {Ode_fit:.2f}, H0={H0_fit:.2f}\")\n",
    "\n",
    "min_chi = np.nanmin(masked_chi_surface)\n",
    "Om_id, Ode_id, H0_id = np.unravel_index(np.nanargmin(masked_chi_surface), masked_chi_surface.shape)\n",
    "Om_manual_fit, Ode_manual_fit, H0_manual_fit = Om[Om_id], Ode[Ode_id], H0[H0_id]\n",
    "print(Om_manual_fit, Ode_manual_fit, H0_manual_fit, min_chi)"
   ]
